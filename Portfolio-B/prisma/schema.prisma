generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  projects Project[]
  skills   Skill[]
}

model Project {
  id         String         @id @default(cuid())
  title      String
  slug       String         @unique
  image      String
  categoryId String
  category   Category       @relation(fields: [categoryId], references: [id])
  details    ProjectDetail?
}

model ProjectDetail {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date         DateTime
  bannerImg    String
  overview     String
  keyFeatures  Json
  technologies Json
  liveLink     String?
}

model Service {
  id        String         @id @default(cuid())
  title     String
  shortDesc String
  tag       String
  hasIcon   Boolean
  stack     Json
  thumbnail String
  details   ServiceDetail?
}

model ServiceDetail {
  id          String  @id @default(cuid())
  serviceId   String  @unique
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  title       String
  description String
  features    Json
  faqs        Json
  notes       Json
  images      Json
}

model Blog {
  id       String      @id @default(cuid())
  img      String
  title    String
  shortDes String
  tag      Json
  date     DateTime    @default(now())
  details  BlogDetail?
}

model BlogDetail {
  id String @id @default(cuid())

  blogId String @unique
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  title           String
  description     String
  images          Json
  tags            Json
  contentSections Json
  author          String
}

model Skill {
  id         String   @id @default(cuid())
  name       String
  iconPath   String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
}

model Experience {
  id         String @id @default(cuid())
  title      String
  percentage Int
}

model Testimonial {
  id       String @id @default(cuid())
  name     String
  role     String
  avatar   String
  feedback String
  rating   Int
}

model FAQ {
  id       String @id @default(cuid())
  category String
  question String
  answer   String
}

model Profile {
  id    String  @id @default(cuid())
  name  String
  email String
  phone String?
  image String?

  entryName String?
  slug      String?

  bannerTitle       Json
  bannerEntryName   String?
  bannerDescription String?
  skillTags         Json?

  aboutTitle       String?
  aboutTagline     Json?
  aboutDescription Json?
  contributions    Json?
  remoteMindset    String?
  tools            Json?
  aboutClosing     String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialLinks SocialLink[]
}

model SocialLink {
  id        String  @id @default(cuid())
  platform  String
  url       String
  iconName  String?
  order     Int     @default(0)
  isActive  Boolean @default(true)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// Contact Form Submissions
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
